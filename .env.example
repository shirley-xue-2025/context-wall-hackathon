# ─────────────────────────────────────────────────────────────
# ContextWall — environment configuration TEMPLATE
# Copy to `.env` and fill in your real keys there (.env is gitignored).
# NEVER put real secrets in this file — it is committed to git.
#
# The demo runs OFFLINE without any keys (Tier 1 is pure code; Tier 2
# falls back to a heuristic). Add keys to unlock the real LLM judge +
# live Apify scraping.
# ─────────────────────────────────────────────────────────────

# --- Tier 2 Semantic Judge (primary: Google AI Studio) ---------
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Fast + cheap + strict JSON schema support. Free-tier friendly.
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Upstream scraper (Apify) ----------------------------------
# https://console.apify.com/settings/integrations  → Personal API token
APIFY_TOKEN=
# Default actor to proxy (override per-call).
APIFY_DEFAULT_ACTOR=polite_bedbug/context-wall-mock-actor

# --- Optional multi-model fallback (OpenRouter) ----------------
# Leave blank for MVP. https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# --- Firewall tuning -------------------------------------------
# How many streamed items to buffer before firing the Tier 2 judge.
CW_JUDGE_SAMPLE_SIZE=3
# Average USD per 1M input tokens of the DOWNSTREAM agent we are
# protecting (used to compute "$ saved" in the dashboard).
CW_DOWNSTREAM_USD_PER_MTOK=3.00
# "mock" forces bundled fixtures; "apify" uses the live cloud actor.
CW_SCRAPER=mock
